# ==========================================
# Family Vault - Backend Environment Setup
# ==========================================

# Port mapping for local development
PORT=5000

# MongoDB Connection URI (for local MongoDB or MongoDB Atlas)
MONGODB_URI=

# JWT Secret Key for token signing and verification
JWT_SECRET=

# AWS Configuration (Used for S3 Bucket and Bedrock AI/Textract)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=



# Connection details targeting your backend microservices
NEXT_PUBLIC_API_URL=http://localhost:5000/api